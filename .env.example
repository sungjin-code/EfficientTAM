# Copy to `.env` and fill in. Training works fine without these — wandb
# logging is simply skipped when WANDB_API_KEY is unset.

# --- Weights & Biases ---
WANDB_API_KEY=
WANDB_PROJECT=efficient-tam
# WANDB_ENTITY=your-team
# WANDB_MODE=disabled   # uncomment to force-disable even with a key set

# --- Paper training script (`./train.sh`) ---
# VARIANT selects the EfficientTAM model size: `ti` or `s`.
VARIANT=ti
CUDA_VISIBLE_DEVICES=0,1
NPROC_PER_NODE=2
TARGET_GLOBAL_BATCH=256
# PYTHON=/path/to/conda/env/bin/python

# --- Data roots ---
# Either set a single DATA_ROOT shared by both stages, or set per-stage values
# (DATA_ROOT_IMAGE / DATA_ROOT_VIDEO) which take precedence when present.
DATA_ROOT=
# DATA_ROOT_IMAGE=/path/to/sa1b_style_root
# DATA_ROOT_VIDEO=/path/to/prepared_sav_root

# --- Paper evaluation roots ---
# VOS roots must use DAVIS-style JPEGImages/{video}/ and Annotations/{video}/.
# VAL_ROOT_VIDEO is accepted as a backward-compatible alias for VAL_ROOT_DAVIS.
# VAL_ROOT_DAVIS=/path/to/davis2017_val_root
# VAL_ROOT_MOSE=/path/to/mose_val_root
# VAL_ROOT_LVOS=/path/to/lvos_val_root
# VAL_ROOT_SAV=/path/to/sav_test_or_val_root
# VAL_ROOT_YTVOS=/path/to/ytvos2019_val_root
# SA23_ROOT=/path/to/sa23_style_root

# --- Dataset preparation (`./download.sh`) ---
# DATA_DIR=datasets
# SA1B_RAW_DIR=/path/to/extracted_sa1b_jpg_json
# SAV_RAW_DIR=/path/to/extracted_sav_mp4_json
# SAV_ANNOTATION_KIND=both
# SAV_ANNOTATION_STRIDE=4
# DOWNLOAD_DAVIS=1

# --- Output (checkpoint) directories ---
# `train.sh` writes to $OUTPUT_DIR/image_$VARIANT and $OUTPUT_DIR/video_$VARIANT
# unless per-stage overrides are set.
OUTPUT_DIR=runs
# OUTPUT_DIR_IMAGE=runs/image_s
# OUTPUT_DIR_VIDEO=runs/video_s

# --- Model weights ---
# Stage-1 checkpoint used to seed stage-2 weights (--init-from).
# INIT_FROM=runs/image_s/image_final.pt
# INIT_FROM_IMAGE=
# INIT_FROM_VIDEO=

# Resume an interrupted run (--resume). Usually points at <output_dir>/<stage>_latest.pt.
# RESUME=runs/video_s/video_latest.pt
# RESUME_IMAGE=
# RESUME_VIDEO=
